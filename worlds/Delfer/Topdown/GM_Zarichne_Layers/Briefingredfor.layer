$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 {
  coords 3581.375 34.51 3165.575
  m_sTitle "Mission Notes"
  m_sTextData "Company CO / Drone Op should lead from their HQ using drone feed to guide the platoons."\
  ""\
  "Medics also spawn at the HQ with a medevac vac or a BMP that can be used for that as well."\
  "Actually medevac your casualties it will be cool."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 7
 }
 {
  coords 3831.342 34.595 2673.115
  m_sTitle "Situation"
  m_sTextData "We have gained a foothold in the enemy's trench line and our lead platoon (AI) is actively engaged within grenade range. If we can push the enemy out of their trench system we can continue onward to capture their position in depth at the farm."\
  ""\
  "Note there are scatterable AT/AP Minefields marked on your map. These marks are general areas, only the trenches themselves are truly safe."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
 }
 {
  coords 3823.163 34.626 2679.487
  m_sTitle "Situation Enemy"
  m_sTextData "Our lead platoon (AI) is in grenade range of a platoon of Ukrainian foreign legion fighters, with reinforcements being sent to reinforce their position now. Some elements are marked on your map. They are occupying positions in depth at the farm as well."\
  ""\
  "They are wearing green brown striped camouflage and are using M16s, M240s, RPGs and UBGL's."\
  ""\
  "They have limited offensive UAS support, if any."\
  ""\
  "They have no counter-UAS."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 1
 }
 {
  coords 3811.363 34.62 2685.558
  m_sTitle "Situation Friendly"
  m_sTextData "We have a platoon (-) (AI) committed in the trench line that we've lost communications with, with a fresh platoon (Players) in the rear most trench."\
  ""\
  "A second reinforcement platoon (Players) is on their way from 022 022."\
  ""\
  "Our COY HQ is located at 018 036 with our drone operators, medical personnel and our vehicles."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 2
 }
 {
  coords 3797.159 34.825 2686.609
  m_sTitle "Mission"
  m_sTextData "Our Company must capture and hold the trench system within 60 minutes. The farm position should be taken if feasible."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 3
 }
 {
  coords 3863.713 34.486 2669.395
  m_sTitle "Execution"
  m_sTextData "The CO and his drone operator should remain at their HQ position and lead the battle via drone feed at least until all respawns have been used and given tasks. "
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 4
 }
 {
  coords 3156.459 31.819 2512.702
  m_sTitle "Service and Support"
  m_sTextData "Located at COY HQ:"\
  ""\
  "1x Recon Drone"\
  "1x Dropper Drone (Grenade)"\
  ""\
  "1x Medevac Van (Seats 4+1 Driver)"\
  "2x UAZ (Seats 5)"\
  "1x BMP-1 (Seats 8+3 Crew) (Can also be used as an armored medevac)"
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 5
 }
 {
  coords 3231.423 33.217 2482.898
  m_sTitle "Command and Signals"
  m_sTextData "110 Coy Commander"\
  "->Drone Operator"\
  ""\
  "121 HQ Platoon Leader"\
  "->121 Platoon Sgt ->121 -> 122 -> 123"\
  ""\
  "131 HQ Platoon Leader"\
  "->131 Platoon Sgt ->131 -> 132 -> 133"\
  ""\
  "Company Net: 42.0MHz"
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 6
 }
